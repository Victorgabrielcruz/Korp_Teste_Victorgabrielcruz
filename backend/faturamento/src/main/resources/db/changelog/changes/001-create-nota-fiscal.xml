<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
    http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

  <changeSet id="001" author="korp">
    <createTable tableName="nota_fiscal">
      <column name="id" type="BIGSERIAL">
        <constraints primaryKey="true" nullable="false"/>
      </column>
      <column name="numero" type="VARCHAR(20)">
        <constraints nullable="false" unique="true"/>
      </column>
      <column name="serie" type="VARCHAR(5)">
        <constraints nullable="false"/>
      </column>
      <column name="data_emissao" type="TIMESTAMP">
        <constraints nullable="false"/>
      </column>
      <column name="valor_total" type="DECIMAL(15,2)">
        <constraints nullable="false"/>
      </column>
      <column name="status" type="VARCHAR(20)" defaultValue="RASCUNHO">
        <constraints nullable="false"/>
      </column>
      <column name="criado_em" type="TIMESTAMP" defaultValueComputed="NOW()">
        <constraints nullable="false"/>
      </column>
    </createTable>
  </changeSet>

  <changeSet id="002" author="korp">
    <createTable tableName="item_nota_fiscal">
      <column name="id" type="BIGSERIAL">
        <constraints primaryKey="true" nullable="false"/>
      </column>
      <column name="nota_fiscal_id" type="BIGINT">
        <constraints nullable="false"
                     foreignKeyName="fk_item_nota_fiscal"
                     references="nota_fiscal(id)"/>
      </column>
      <column name="produto_id" type="BIGINT">
        <constraints nullable="false"/>
      </column>
      <column name="quantidade" type="DECIMAL(15,4)">
        <constraints nullable="false"/>
      </column>
      <column name="preco_unitario" type="DECIMAL(15,2)">
        <constraints nullable="false"/>
      </column>
      <column name="valor_total" type="DECIMAL(15,2)">
        <constraints nullable="false"/>
      </column>
    </createTable>
  </changeSet>

</databaseChangeLog>
