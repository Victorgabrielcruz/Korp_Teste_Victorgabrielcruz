<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
    http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

  <changeSet id="001" author="korp">
    <createTable tableName="produto">
      <column name="id" type="BIGSERIAL">
        <constraints primaryKey="true" nullable="false"/>
      </column>
      <column name="codigo" type="VARCHAR(50)">
        <constraints nullable="false" unique="true"/>
      </column>
      <column name="descricao" type="VARCHAR(255)">
        <constraints nullable="false"/>
      </column>
      <column name="unidade_medida" type="VARCHAR(10)">
        <constraints nullable="false"/>
      </column>
      <column name="saldo" type="DECIMAL(15,4)" defaultValue="0">
        <constraints nullable="false"/>
      </column>
      <column name="preco_unitario" type="DECIMAL(15,2)">
        <constraints nullable="false"/>
      </column>
      <column name="criado_em" type="TIMESTAMP" defaultValueComputed="NOW()">
        <constraints nullable="false"/>
      </column>
      <column name="atualizado_em" type="TIMESTAMP" defaultValueComputed="NOW()">
        <constraints nullable="false"/>
      </column>
    </createTable>
  </changeSet>

</databaseChangeLog>
